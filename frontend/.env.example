# ─── Frontend Environment Variables ──────────────────────────────────────────
# Copy this file to .env and fill in the values.
#
# NEXT_PUBLIC_* variables are embedded at build time by Next.js and shipped
# to the browser. Never put secrets here.

# Base URL of the backend API (used by the client SDK)
NEXT_PUBLIC_API_URL=http://localhost:3001/api/v1

# Public-facing URL of this frontend (used for OG meta tags, canonical links)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Stellar Horizon URL (used for wallet/account lookups)
NEXT_PUBLIC_HORIZON_URL=https://horizon-testnet.stellar.org

# Stellar RPC URL (Soroban contract interaction)
NEXT_PUBLIC_STELLAR_RPC_URL=https://soroban-testnet.stellar.org

# Stellar network passphrase
NEXT_PUBLIC_STELLAR_NETWORK_PASSPHRASE=Test SDF Network ; September 2015

# Stellar explorer URL (for building transaction/account links)
NEXT_PUBLIC_STELLAR_EXPLORER_URL=https://stellar.expert

# Soroban smart contract IDs
NEXT_PUBLIC_MANAGER_CONTRACT_ID=
NEXT_PUBLIC_LOAN_MANAGER_CONTRACT_ID=
NEXT_PUBLIC_NFT_CONTRACT_ID=
