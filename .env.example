# ── ZizaLend — Environment Configuration ─────────────────────────
# Copy this file to .env and fill in your values.
# See docs/ENVIRONMENT.md for detailed documentation on every variable.
#
#   cp .env.example .env

# ── Backend ───────────────────────────────────────────────────────
# Node environment: development | production | test | staging
NODE_ENV=development

# Database connection (PostgreSQL)
DATABASE_URL=postgres://postgres:postgres@localhost:5432/ZizaLend

# Redis connection (for caching, rate limiting, idempotency)
REDIS_URL=redis://localhost:6379

# Frontend URL (required in production for CORS)
FRONTEND_URL=http://localhost:3000

# Stellar network configuration
STELLAR_NETWORK=testnet
STELLAR_RPC_URL=https://soroban-testnet.stellar.org
STELLAR_NETWORK_PASSPHRASE=Test SDF Network ; September 2015

# Stellar secret key for the admin account that deploys contracts
# and signs governance operations (store securely!)
STELLAR_ADMIN_SECRET=

# Sentry DSN for error tracking
SENTRY_DSN=
SENTRY_ORG=
SENTRY_PROJECT=
SENTRY_AUTH_TOKEN=

# ── Frontend ───────────────────────────────────────────────────────
# These are injected at build time (Next.js public env vars)
NEXT_PUBLIC_API_URL=http://localhost:3001
NEXT_PUBLIC_RPC_URL=https://soroban-testnet.stellar.org
NEXT_PUBLIC_NETWORK_PASSPHRASE=Test SDF Network ; September 2015
NEXT_PUBLIC_EXPLORER_URL=https://stellar.expert/explorer/testnet

# Smart contract IDs (set after deployment via scripts/deploy.ts)
NEXT_PUBLIC_MANAGER_CONTRACT_ID=
NEXT_PUBLIC_POOL_CONTRACT_ID=
NEXT_PUBLIC_GOVERNANCE_CONTRACT_ID=
NEXT_PUBLIC_NFT_CONTRACT_ID=

# ── Smart Contracts ────────────────────────────────────────────────
# Admin wallet key for contract governance operations (hex-encoded secret)
CONTRACT_ADMIN_SECRET=

# ── Docker (optional) ──────────────────────────────────────────────
# Override defaults when running via docker-compose
# COMPOSE_PROJECT_NAME=zizalend
